    "tenancy": {
      "model": "none"
    },
    "outOfScope": [
      "Public internet exposure",
      "Multi-tenant deployment",
      "Use outside the corporate identity domain",
      "Self-service deployment by business units (centrally operated only)"
    ]
  },
